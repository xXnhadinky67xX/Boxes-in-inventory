# FUNCTION: greet_user
# Purpose: Greets the user when they enter the program
def greet_user(name):
    print("Hello", name, "! You are in the home page!") 

# FUNCTION: display_stock
# Purpose: Shows current inventory status
# If stock is 0 or less, shows OUT OF STOCK
def display_stock(apple, orange, peanut, choco):
    print("===== STORE STOCK =====")
    # If stock is greater than 0, display quantity; otherwise show "OUT OF STOCK"
    print("Apple Juice:", apple if apple > 0 else "OUT OF STOCK")
    print("Orange Juice:", orange if orange > 0 else "OUT OF STOCK")
    print("Peanut Presco:", peanut if peanut > 0 else "OUT OF STOCK")
    print("Choco Presco:", choco if choco > 0 else "OUT OF STOCK")

# FUNCTION: manager_menu
# Purpose: Allows manager to view inventory
def manager_menu(name, apple, orange, peanut, choco):
    print("Welcome,", name, "!")

    # Loop so manager can choose multiple actions
    while True:
        print("1. View total number of items in Inventory")
        print("2. Back")

        sub = input("Choose: ")

        # If manager chooses to view stock
        if sub == "1":
            display_stock(apple, orange, peanut, choco)

        # Exit manager menu
        elif sub == "2":
            break

        # Invalid input handling
        else:
            print("Invalid input.")

# FUNCTION: cashier_menu
# Purpose: Updates inventory (imports/exports)def cashier_menu(apple, orange, peanut, choco):
    print("Welcome, Cashier!")

    while True:
        print("1. Input imported/exported items")
        print("2. Back")

        sub = input("Enter choice: ")

        # Update stock values
        if sub == "1":

            # INPUT IMPORTED AND EXPORTED VALUES
            imported_apple = int(input("Apple imported: "))
            exported_apple = int(input("Apple exported: "))

            imported_orange = int(input("Orange imported: "))
            exported_orange = int(input("Orange exported: "))

            imported_peanut = int(input("Peanut Presco imported: "))
            exported_peanut = int(input("Peanut Presco exported: "))

            imported_choco = int(input("Choco Presco imported: "))
            exported_choco = int(input("Choco Presco exported: "))

            # UPDATE INVENTORY VALUES
            apple += imported_apple - exported_apple
            orange += imported_orange - exported_orange
            peanut += imported_peanut - exported_peanut
            choco += imported_choco - exported_choco

            print("Updated Inventory:")
            display_stock(apple, orange, peanut, choco)

        # Exit cashier menu
        elif sub == "2":
            break

        # Invalid input
        else:
            print("Invalid choice.")

    # Return updated values to main program
    return apple, orange, peanut, choco


# FUNCTION: customer_menu
# Purpose: Allows customers to view stock only
def customer_menu(apple, orange, peanut, choco):
    while True:
        print("1. Check product stock")
        print("2. Back")

        choice = input("Enter choice: ")

        # Show stock
        if choice == "1":
            display_stock(apple, orange, peanut, choco)

        # Exit menu
        elif choice == "2":
            break

        # Invalid input
        else:
            print("Invalid choice.")


# MAIN PROGRAM START

# Ask user name
name = input("Please enter your name: ")

# Greeting message
greet_user(name)

# INITIAL INVENTORY VALUES
apple_juice = 50
orange_juice = 50
peanut_presco = 50
choco_presco = 50


# MAIN LOOP (HOME PAGE)
while True:
    print("=== HOME PAGE ===")
    print("1. Manager")
    print("2. Cashier")
    print("3. Customer")
    print("4. Exit")

    choice = input("Select your role: ")

    # Manager access
    if choice == "1":
        manager_menu(name, apple_juice, orange_juice, peanut_presco, choco_presco)

    # Cashier access (updates stock)
    elif choice == "2":
        apple_juice, orange_juice, peanut_presco, choco_presco = cashier_menu(
            apple_juice, orange_juice, peanut_presco, choco_presco
        )

    # Customer access (view only)
    elif choice == "3":
        customer_menu(apple_juice, orange_juice, peanut_presco, choco_presco)

    # Exit program
    elif choice == "4":
        print("Exiting program. Goodbye!")
        break

    # Invalid menu choice
    else:
        print("Invalid choice. Please try again.")
